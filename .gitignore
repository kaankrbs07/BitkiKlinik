# ==========================================
# BitkiKlinik Projesi Kapsamlı .gitignore
# ==========================================

# ── 0. GÜVENLİK VE ORTAM DEĞİŞKENLERİ (.env) ──
.env
.env.local
.env.*

# ── 1. İŞLETİM SİSTEMİ DOSYALARI (OS Files) ──
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
*.har

# ── 2. EDİTÖR VE IDE DOSYALARI (IDEs & Editors) ──
.idea/
.vscode/
.vs/
**/.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.swp
*.swo
.project
.classpath
.settings/
.visualstudio/
out/

# ── 3. .NET BACKEND GÜVENLİK VE DERLEME (C# / .NET API) ──
**/bin/
**/obj/
**/App_Data/*.ldf
**/App_Data/*.mdf
**/wwwroot/uploads/*
!**/wwwroot/uploads/.gitkeep
**/appsettings.Development.json
**/BitkiKlinik.API/keys/
*.db
*.sqlite

# ── 4. REACT NATIVE & EXPO MOBİL UYGULAMA (Frontend App) ──
**/node_modules/
**/.expo/
**/coverage/
**/dist/
**/web-build/
**/npm-debug.*
**/yarn-debug.*
**/yarn-error.*
**/.env*.local
**/.env
**/.kotlin/
**/*.orig.*
**/*.jks
**/*.p8
**/*.p12
**/*.key
**/*.mobileprovision
**/.metro-health-check*
**/*.tsbuildinfo
**/ios/
**/android/

# ── 5. PYTHON VE ML SERVİSİ (Python / Machine Learning) ──
**/venv/
**/.venv/
**/env/
**/ENV/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.ipynb_checkpoints/
**/.pytest_cache/
**/.tox/
**/.coverage
**/htmlcov/
**/*.log
**/BitkiKlinik.ML/data/*
!**/BitkiKlinik.ML/data/.gitkeep
**/BitkiKlinik.ML/outputs/*
!**/BitkiKlinik.ML/outputs/.gitkeep
**/BitkiKlinik.ML/models/*.h5
**/BitkiKlinik.ML/models/*.pkl
**/BitkiKlinik.ML/models/*.pt
**/BitkiKlinik.ML/models/*.onnx
**/BitkiKlinik.ML/Dependencies.zip
