{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ActiveLearning": {
    "ConfidenceThreshold": 0.65,
    "ImageStoragePath": "wwwroot/uploads/active-learning"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_DB_SERVER;Database=PlantClinicDB;User Id=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Key": "YOUR_JWT_SECRET_KEY_PLACEHOLDER",
    "Issuer": "BitkiKlinikAPI",
    "Audience": "BitkiKlinikMobileApp",
    "ExpireMinutes": 1440
  },
  "PythonApi": {
    "BaseUrl": "http://127.0.0.1:8000",
    "AnalyzeEndpoint": "/analyze",
    "TimeoutSeconds": 30,
    "AddSampleEndpoint": "/active-learning/add-sample",
    "RetrainEndpoint": "/active-learning/retrain",
    "RetrainStatusEndpoint": "/active-learning/retrain-status"
  },
  "FileStorage": {
    "Provider": "Backblaze",
    "BasePath": "wwwroot/uploads",
    "UploadPath": "wwwroot/uploads/scans",
    "AllowedExtensions": [
      ".jpg",
      ".jpeg",
      ".png",
      ".webp"
    ],
    "MaxFileSizeMb": 10,
    "Backblaze": {
      "BucketName": "YOUR_B2_BUCKET_NAME",
      "Endpoint": "YOUR_B2_ENDPOINT",
      "KeyId": "YOUR_B2_KEY_ID",
      "ApplicationKey": "YOUR_B2_APPLICATION_KEY",
      "Region": "YOUR_B2_REGION",
      "PreSignedUrlDurationHours": 24
    }
  },
  "SMTP": {
    "Host": "smtp.gmail.com",
    "Port": 465,
    "SenderName": "Bitki Klinik",
    "SenderEmail": "YOUR_SMTP_SENDER_EMAIL",
    "Username": "YOUR_SMTP_USERNAME",
    "Password": "YOUR_SMTP_PASSWORD",
    "UseStartTls": false,
    "UseSsl": true,
    "UseOAuth2": false
  },
  "Gemini": {
    "ApiKey": "YOUR_GEMINI_API_KEY",
    "BaseUrl": "https://generativelanguage.googleapis.com",
    "Model": "gemini-3.5-flash"
  },
  "RabbitMQ": {
    "ConnectionString": "amqp://***REMOVED***@localhost:5672/",
    "QueueName": "bitkiklinik.retrain"
  }
}